{
  "version": 2,
  "cleanUrls": true,
  "trailingSlash": false,
  "functions": {
    "pages/**/*.php": {
      "runtime": "vercel-php@0.6.0"
    },
    "admin/**/*.php": {
      "runtime": "vercel-php@0.6.0"
    }
  },
  "routes": [
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/$1" }
  ]
}